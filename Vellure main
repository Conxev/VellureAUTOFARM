local QueueOnTeleport = queue_on_teleport or queueonteleport
local RunOnThread = run_on_thread or runonthread
local RunOnActor = run_on_actor or runonactor
local GetActorThreads = get_actor_threads or getactorthreads
local GetDeletedActors = get_deleted_actors or getdeletedactors

local TARGET_PLACE_ID = 77747658251236

local function StartTeleport()
    if not QueueOnTeleport then
        (setclipboard or function() end)("https://www.youtube.com/watch?v=wr__SjSUjAU")
        game.Players.LocalPlayer:Kick("QueueOnTeleport not supported by your executor.\nWatch the video for fixes.")
        return
    end

    (setfflag or function() end)("DebugRunParallelLuaOnMainThread", "True")

    QueueOnTeleport([[
        repeat task.wait() until game:IsLoaded()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Conxev/VellureAUTOFARM/refs/heads/main/Vellure%20main"))()
    ]])

    game:GetService("TeleportService"):Teleport(TARGET_PLACE_ID, game.Players.LocalPlayer)
end

if game.PlaceId == TARGET_PLACE_ID then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Conxev/VellureAUTOFARM/refs/heads/main/Vellure%20main"))()
else
    if RunOnThread or RunOnActor then
        local GetNeeded = RunOnThread and (GetActorThreads or function() return {} end) 
                       or (RunOnActor and GetDeletedActors)

        local Actor = GetNeeded and GetNeeded()[1]
        if Actor then
            pcall(function()
                (RunOnThread or RunOnActor)(Actor, [[
                    loadstring(game:HttpGet("https://raw.githubusercontent.com/Conxev/VellureAUTOFARM/refs/heads/main/Vellure%20main"))()
                ]])
            end)
        end
    end

    StartTeleport()
end
